    <formulas>
        <name>frmClientOverviewText</name>
        <dataType>String</dataType>
        <expression>&quot;Client Name: &quot; &amp;
{!Get_Client_Record.Name} &amp;
BR() &amp;
&quot;Email: &quot; &amp;
{!Get_Client_Record.Email__c}</expression>
    </formulas>
    <formulas>
        <name>frmCurrentFinancialAccountLine</name>
        <dataType>String</dataType>
        <expression>&quot;Financial Account: &quot; &amp;
{!Loop_Through_Financial_Accounts.Name} &amp;
&quot; | Type: &quot; &amp;
TEXT({!Loop_Through_Financial_Accounts.FinServ__FinancialAccountType__c}) &amp;
&quot; | Balance:  $&quot; &amp;
TEXT({!Loop_Through_Financial_Accounts.FinServ__Balance__c}) &amp;
&quot; | Holdings: &quot; &amp;
TEXT({!Loop_Through_Financial_Accounts.FinServ__HoldingCount__c}) &amp;
&quot; | Status: &quot; &amp;
TEXT({!Loop_Through_Financial_Accounts.FinServ__Status__c}) &amp;
BR()</expression>
    </formulas>
    <formulas>
        <name>frmCurrentHoldingLine</name>
        <dataType>String</dataType>
        <expression>&quot;- Holding: &quot; &amp;
{!Loop_Through_Financial_Holdings.Name} &amp;
&quot; | Asset Class: &quot; &amp;
IF(
  ISBLANK(TEXT({!Loop_Through_Financial_Holdings.FinServ__AssetClass__c})),
  &quot;N/A&quot;,
  TEXT({!Loop_Through_Financial_Holdings.FinServ__AssetClass__c})
) &amp;
&quot; | Category: &quot; &amp;
IF(
  ISBLANK(TEXT({!Loop_Through_Financial_Holdings.FinServ__AssetCategory__c})),
  &quot;N/A&quot;,
  TEXT({!Loop_Through_Financial_Holdings.FinServ__AssetCategory__c})
) &amp;
&quot; | Market Value: $&quot; &amp;
TEXT({!Loop_Through_Financial_Holdings.FinServ__MarketValue__c}) &amp;
&quot; | Shares: &quot; &amp;
TEXT({!Loop_Through_Financial_Holdings.FinServ__Shares__c}) &amp;
&quot; | Sector: &quot; &amp;
IF(
  ISBLANK(TEXT({!Loop_Through_Financial_Holdings.Sector__c})),
  &quot;N/A&quot;,
  TEXT({!Loop_Through_Financial_Holdings.Sector__c})
) &amp;
&quot; | % Change: &quot; &amp;
TEXT({!Loop_Through_Financial_Holdings.FinServ__PercentChange__c}) &amp;
BR()</expression>
    </formulas>
    <formulas>
        <name>frmCurrentLifeEventLine</name>
        <dataType>String</dataType>
        <expression>&quot;- &quot; &amp;
TEXT({!Loop_Through_Life_Events.FinServ__EventType__c}) &amp;
&quot; | &quot; &amp;
TEXT({!Loop_Through_Life_Events.FinServ__EventDate__c}) &amp;
&quot; | &quot; &amp;
BLANKVALUE({!Loop_Through_Life_Events.Description__c}, &quot;&quot;) &amp;
BR()</expression>
    </formulas>
    <formulas>
        <name>frmFamilyMilestonesFinal</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK({!varFamilyMilestonesText}),
  &quot;No family milestones found.&quot;,
  {!varFamilyMilestonesText}
)</expression>
    </formulas>
    <formulas>
        <name>frmPortfolioFinal</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK({!varPortfolioText}),
  &quot;No portfolio details found.&quot;,
  {!varPortfolioText}
)</expression>
    </formulas>
    <formulas>
        <name>frmPromptInputText</name>
        <dataType>String</dataType>
        <expression>&quot;Client Overview&quot; &amp;
BR() &amp;
{!varClientOverviewText} &amp;
BR() &amp; BR() &amp;
&quot;Family Milestones&quot; &amp;
BR() &amp;
{!frmFamilyMilestonesFinal} &amp;
BR() &amp; BR() &amp;
&quot;Recent Work History&quot; &amp;
BR() &amp;
{!frmWorkHistoryFinal} &amp;
BR() &amp; BR() &amp;
&quot;Current Portfolio&quot; &amp;
BR() &amp;
{!frmPortfolioFinal}</expression>
    </formulas>
    <formulas>
        <name>frmTaskDescription</name>
        <dataType>String</dataType>
        <expression>&quot;Client 360 Pre-Call Brief:&quot; &amp;
BR() &amp; BR() &amp;
{!varGeneratedSummary} &amp;
BR() &amp; BR() &amp;
&quot;Generated via Market Monitoring Agent&quot;</expression>
    </formulas>
    <formulas>
        <name>frmWorkHistoryFinal</name>
        <dataType>String</dataType>
        <expression>IF(
  ISBLANK({!varWorkHistoryText}),
  &quot;No recent work history found.&quot;,
  {!varWorkHistoryText}
)</expression>
    </formulas>
