    <decisions>
        <name>Classify_Life_Event</name>
        <label>Classify Life Event</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_Through_Life_Events</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Family_Milestone</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Through_Life_Events.FinServ__EventType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New Baby</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_Life_Events.FinServ__EventType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New Home</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_Life_Events.FinServ__EventType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>College</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Append_Family_Milestone_Text</targetReference>
            </connector>
            <label>Is Family Milestone</label>
        </rules>
        <rules>
            <name>Is_Work_History</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Through_Life_Events.FinServ__EventType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New Job</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_Life_Events.FinServ__EventType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>New Business</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Through_Life_Events.FinServ__EventType__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Retirement</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Append_Work_History_Text</targetReference>
            </connector>
            <label>Is Work History</label>
        </rules>
    </decisions>
